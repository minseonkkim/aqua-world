<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="aquaworld.app" android:host="oauth" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

        <!-- FCM 기본 알림 채널 (Android 8+ 필수). 채널 자체는 PushNotifications.createChannel 로 생성. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="aquaworld_default" />

        <!-- 알림 상태바 small icon (흰색 단색 실루엣). 미지정 시 앱 런처 아이콘이 회색 사각형으로 표시됨. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_notify" />
        <!-- 흰색 실루엣에 적용되는 틴트 색 -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/aquaworld_notification" />

        <!-- AdMob APPLICATION_ID. 현재는 Google 공식 테스트 ID. 실서비스 빌드 전에 AdMob 콘솔에서 발급한 실제 값으로 교체 필수. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-2189275813205372~8805884871" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ 런타임 알림 권한. 미만 버전은 자동 허용. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
</manifest>
