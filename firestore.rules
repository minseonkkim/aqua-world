rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 모든 쓰기는 서버(Cloud Functions / Admin SDK)만 수행한다 — Admin SDK 는 규칙을
    // 우회하므로 클라이언트 직접 쓰기는 전면 차단한다. 클라는 본인 문서 읽기만 가능.
    // (경제·어종은 전용 함수, 꾸미기/청결도/데코 인벤토리는 saveTankCosmetics,
    //  튜토리얼 완료 신호는 setTutorialStep 으로만 변경된다.)

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // 인앱결제 멱등 기록 — 서버(Admin)만 읽고 쓴다. 클라이언트 접근 전면 차단.
    match /purchases/{purchaseToken} {
      allow read, write: if false;
    }

    // 베타 피드백 — 서버(submitFeedback, Admin)만 기록한다. 클라이언트 직접 접근 전면 차단.
    match /feedback/{feedbackId} {
      allow read, write: if false;
    }

    match /tanks/{tankId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow write: if false;
    }
  }
}
