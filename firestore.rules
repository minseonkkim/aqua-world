rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 모든 쓰기는 서버(Cloud Functions / Admin SDK)만 수행한다 — Admin SDK 는 규칙을
    // 우회하므로 클라이언트 직접 쓰기는 전면 차단한다. 클라는 본인 문서 읽기만 가능.
    // (경제·어종은 전용 함수, 꾸미기/청결도/데코 인벤토리는 saveTankCosmetics,
    //  튜토리얼 완료 신호는 setTutorialStep 으로만 변경된다.)

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // 친구 데이터(friends / requestsIn / requestsOut / visits)와 친구 코드 인덱스는
    // 서버 전용이다. 규칙은 상위 문서에서 하위 컬렉션으로 상속되지 않고, 어떤 match 도
    // 이들에 allow 를 주지 않으므로 기본 거부(default deny)로 이미 막혀 있다.
    // 아래 블록은 그 사실을 코드로 남겨두기 위한 문서용이다 — allow 는 OR 로 합쳐지므로
    // `if false` 자체에는 차단 효력이 없다(위 users/{uid} 본인 읽기를 무효화하지도 않는다).
    // 클라는 친구 목록을 listFriends 로만 받는다. 친구 프로필은 남의 users 문서라
    // 직접 읽을 수 없고, 서버가 공개 필드만 정제해 돌려준다.
    // friendCodes 는 코드 → uid 역추적을 막기 위해 조회도 함수(findUserByFriendCode) 경유.
    match /users/{uid}/{sub=**} {
      allow read, write: if false;
    }
    match /friendCodes/{code} {
      allow read, write: if false;
    }

    // 인앱결제 멱등 기록 — 서버(Admin)만 읽고 쓴다. 클라이언트 접근 전면 차단.
    match /purchases/{purchaseToken} {
      allow read, write: if false;
    }

    // 베타 피드백 — 서버(submitFeedback, Admin)만 기록한다. 클라이언트 직접 접근 전면 차단.
    match /feedback/{feedbackId} {
      allow read, write: if false;
    }

    match /tanks/{tankId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow write: if false;
    }
  }
}
