{
  "name": "aquaworld",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run gen:licenses && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "type-check": "tsc -b --noEmit",
    "gen:fish": "node scripts/generate-fish-models.mjs && node scripts/compress-models.mjs",
    "gen:decoration": "node scripts/generate-decoration-models.mjs && node scripts/compress-models.mjs",
    "gen:models:compress": "node scripts/compress-models.mjs",
    "gen:icons": "node scripts/generate-icons.mjs",
    "gen:notify-icon": "node scripts/generate-notification-icon.mjs",
    "gen:native-assets": "node scripts/generate-native-assets.mjs",
    "gen:licenses": "node scripts/generate-licenses.mjs",
    "cap:assets": "npm run gen:native-assets && capacitor-assets generate --android --iconBackgroundColor #0a1628 --iconBackgroundColorDark #0a1628 --splashBackgroundColor #0a1628 --splashBackgroundColorDark #0a1628",
    "cap:build": "cross-env VITE_TARGET=capacitor npm run build && cap sync",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:run:android": "cross-env VITE_TARGET=capacitor npm run build && cap sync android && cap run android",
    "cap:livereload:android": "cross-env VITE_TARGET=capacitor cap run android --live-reload --external"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor-community/media": "^8.0.1",
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@sentry/react": "^10.55.0",
    "firebase": "^12.14.0",
    "howler": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "three": "^0.170.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@types/howler": "^2.2.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "draco3dgltf": "^1.5.7",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "prettier": "^3.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  },
  "private": true
}
